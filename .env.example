NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Proxy
UPSTREAM_BASE_URL=https://api.openai.com
UPSTREAM_API_KEY=                  # optional: override consumer's key for upstream
PROXY_API_KEY=                     # optional: if set, consumers must send this as Bearer token
PROXY_TIMEOUT_MS=300000
TELEMETRY_MAX_BODY_BYTES=1048576   # max response size to capture for telemetry (1MB)

# Anthropic (for /v1/messages pass-through)
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=                 # optional: override consumer's key for Anthropic
ANTHROPIC_VERSION=2023-06-01

# Gemini (for /v1beta/* pass-through)
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_API_KEY=                    # optional: override consumer's key for Gemini

# DeepSeek (OpenAI-compatible, for /deepseek/v1/* pass-through)
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=                  # optional: override consumer's key for DeepSeek

# Langfuse (leave empty to disable telemetry)
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
