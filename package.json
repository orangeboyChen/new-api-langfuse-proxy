{
  "name": "langfuse-proxy",
  "version": "0.0.0",
  "private": true,
  "module": "src/index.ts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/fazer-ai/langfuse-proxy.git"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "test": "bun test --coverage",
    "test-watch": "bun test --watch",
    "lint": "bun biome check --error-on-warnings",
    "format": "bun biome check --write",
    "build-check": "bunx tsc --noEmit",
    "check": "bun run lint && bun run build-check && bun run test",
    "prepare": "husky"
  },
  "dependencies": {
    "elysia": "1.4.28",
    "langfuse": "^3.38.20",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.14",
    "husky": "^9.1.7",
    "pino-caller": "^4.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
